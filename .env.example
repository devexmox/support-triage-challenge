# Copy this file to .env and fill in the key we give you at the start of the session.
# AWS Bedrock OpenAI-compatible endpoint: https://aws.amazon.com/bedrock/openai/
AWS_REGION=us-west-2
OPENAI_BASE_URL=https://bedrock-runtime.us-west-2.amazonaws.com/openai/v1
OPENAI_API_KEY=sk-...
# Optional: override the default model
OPENAI_MODEL=openai.gpt-oss-120b-1:0
